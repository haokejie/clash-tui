# Optional overrides for packaging/clash-tui/systemd/clash-tui.service.
# Copy to /etc/clash-tui/env and chmod 600.

# Package defaults. Override only when moving package directories.
# CLASH_TUI_HOME=/var/lib/clash-tui
# CLASH_TUI_RESOURCE_DIR=/opt/clash-tui/resources
# CLASH_TUI_MIHOMO_BIN=/opt/clash-tui/resources/mihomo

# Automatic subscription refresh scan interval, in seconds.
# Startup also performs an immediate due subscription sweep.
# CLASH_TUI_SUBSCRIPTION_CHECK_INTERVAL_SECS=300
